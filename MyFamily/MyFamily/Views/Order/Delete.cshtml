@model Order

@{
    ViewBag.Title = "Xóa Đơn Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .delete-container {
        max-width: 600px;
        margin: 20px 0;
        background-color: #fff;
        border: 1px solid #ddd;
        padding: 20px;
        border-radius: 5px;
    }

    .delete-container h2 {
        color: #cc0000;
        margin-bottom: 20px;
    }

    .warning-box {
        background-color: #fff3cd;
        border: 1px solid #ffc107;
        border-radius: 3px;
        padding: 15px;
        margin-bottom: 20px;
    }

    .warning-box h3 {
        color: #856404;
        margin-top: 0;
    }

    .order-info {
        background-color: #f9f9f9;
        border-left: 4px solid #cc0000;
        padding: 15px;
        margin: 20px 0;
        border-radius: 3px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 8px 0;
        border-bottom: 1px solid #ddd;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        font-weight: bold;
        color: #333;
    }

    .info-value {
        color: #666;
    }

    .button-group {
        display: flex;
        gap: 10px;
        margin-top: 20px;
    }

    .btn {
        padding: 10px 20px;
        text-decoration: none;
        border-radius: 3px;
        border: none;
        cursor: pointer;
        font-weight: bold;
        flex: 1;
    }

    .btn-delete {
        background-color: #cc0000;
        color: white;
    }

    .btn-delete:hover {
        background-color: #990000;
    }

    .btn-cancel {
        background-color: #666;
        color: white;
    }

    .btn-cancel:hover {
        background-color: #555;
    }
</style>

<div class="delete-container">
    <h2>@ViewBag.Title</h2>

    <div class="warning-box">
        <h3>⚠️ Cảnh Báo</h3>
        <p>Bạn sắp xóa đơn hàng này. Hành động này không thể hoàn tác. Vui lòng xác nhận lại trước khi xóa.</p>
    </div>

    <div class="order-info">
        <div class="info-row">
            <span class="info-label">Đơn Hàng ID:</span>
            <span class="info-value">@Model.OrderId</span>
        </div>
        <div class="info-row">
            <span class="info-label">Khách Hàng:</span>
            <span class="info-value">@Model.Customer.Name</span>
        </div>
        <div class="info-row">
            <span class="info-label">Ngày Đặt:</span>
            <span class="info-value">@Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</span>
        </div>
        <div class="info-row">
            <span class="info-label">Tổng Tiền:</span>
            <span class="info-value">@Model.TotalAmount.ToString("N0") K</span>
        </div>
        <div class="info-row">
            <span class="info-label">Tiền Đã Thu:</span>
            <span class="info-value">@Model.PaidAmount.ToString("N0") K</span>
        </div>
        <div class="info-row">
            <span class="info-label">Tiền Chưa Thu:</span>
            <span class="info-value">@Model.DebtAmount.ToString("N0") K</span>
        </div>
    </div>

    @using (Html.BeginForm("Delete", "Order", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(model => model.OrderId)

        <div class="button-group">
            <button type="submit" class="btn btn-delete">Xóa Đơn Hàng</button>
            @Html.ActionLink("Hủy", "Index", null, new { @class = "btn btn-cancel" })
        </div>
    }
</div>
